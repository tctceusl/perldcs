% Factorial
fact(0,1). 
fact(N,F):- N>0, N1 is N-1, fact(N1,F1), F is N*F1.

% nCr
nCr(N,R,C):- fact(N,FN), fact(R,FR), NR is N-R, fact(NR,FNR), C is FN // (FR*FNR).

% Print row
print_row(N):- between(0,N,C), nCr(N,C,V), write(V), write(' '), fail; nl.

% Print triangle
print_triangle(N):- N1 is N-1, between(0,N1,R), print_row(R), fail; true.


