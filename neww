% Base case: only 1 disk
hanoi(1, From, _, To) :-
    format('Move disk from ~w to ~w~n', [From, To]).

% Recursive case: N > 1
hanoi(N, From, Aux, To) :-
    N > 1,
    N1 is N - 1,
    hanoi(N1, From, To, Aux),   % Move N-1 disks to Aux
    hanoi(1,  From, Aux, To),   % Move biggest disk to To
    hanoi(N1, Aux,  From, To).  % Move N-1 disks to To
	
	
