% Make it undirected (both ways move panna)
edge(A,B) :- connected(A,B).
edge(A,B) :- connected(B,A).

% --------- Route finding ----------
% solve(P) -> P is the path list
solve(Path) :-
    start(S),
    dfs(S, [S], RevPath),
    reverse_list(RevPath, Path).

% Goal reached (cut = first found path mattum)
dfs(Node, Visited, Visited) :-
    goal(Node), !.

dfs(Node, Visited, Path) :-
    edge(Node, Next),
    \+ member(Next, Visited),      % GNU Prolog built-in member/2 use panrom
    dfs(Next, [Next|Visited], Path).

% --------- List reverse ----------
reverse_list(L, R) :- rev_acc(L, [], R).
rev_acc([], Acc, Acc).
rev_acc([H|T], Acc, R) :- rev_acc(T, [H|Acc], R).

% --------- Print path one-per-line ----------
