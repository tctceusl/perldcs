initial(state(3,3,left)).
goal(state(0,0,right)).

safe(state(M,C,_)) :-
    M >= 0, C >= 0, M =< 3, C =< 3,
    (M >= C ; M = 0),
    M2 is 3-M, C2 is 3-C,
    (M2 >= C2 ; M2 = 0).

move(state(M,C,left), state(M1,C,right)) :- M1 is M-1, safe(state(M1,C,right)).
move(state(M,C,left), state(M2,C,right)) :- M2 is M-2, safe(state(M2,C,right)).
move(state(M,C,left), state(M,C1,right)) :- C1 is C-1, safe(state(M,C1,right)).
move(state(M,C,left), state(M,C2,right)) :- C2 is C-2, safe(state(M,C2,right)).
move(state(M,C,left), state(M1,C1,right)) :- M1 is M-1, C1 is C-1, safe(state(M1,C1,right)).

move(state(M,C,right), state(M1,C,left)) :- M1 is M+1, safe(state(M1,C,left)).
move(state(M,C,right), state(M2,C,left)) :- M2 is M+2, safe(state(M2,C,left)).
move(state(M,C,right), state(M,C1,left)) :- C1 is C+1, safe(state(M,C1,left)).
move(state(M,C,right), state(M,C2,left)) :- C2 is C+2, safe(state(M,C2,left)).
move(state(M,C,right), state(M1,C1,left)) :- M1 is M+1, C1 is C+1, safe(state(M1,C1,left)).

solve :-
