/* 1. Member */
my_member(X, [X|_]).
my_member(X, [_|T]) :-
    my_member(X, T).

/* 2. Length */
my_length([], 0).
my_length([_|T], N) :-
    my_length(T, N1),
    N is N1 + 1.

/* 3. Append */
my_append([], L, L).
my_append([H|T], L, [H|R]) :-
    my_append(T, L, R).

/* 4. Sum */
my_sum([], 0).
my_sum([H|T], Sum) :-
    my_sum(T, S1),
    Sum is H + S1.

/* 5. Reverse */
my_reverse([], []).
my_reverse([H|T], R) :-
    my_reverse(T, RT),
    my_append(RT, [H], R).

/* 6. Palindrome */
palindrome(L) :-
    my_reverse(L, L).

% 7. Maximum 
my_max([X], X).
my_max([H|T], Max) :-
    my_max(T, MaxT),
    (H > MaxT -> Max = H ; Max = MaxT).

/* 8. Delete Element */
my_delete(X, [X|T], T).
my_delete(X, [H|T], [H|R]) :-
    my_delete(X, T, R).

/* 9. Even Numbers Only */
even_list([], []).
even_list([H|T], [H|R]) :-
    H mod 2 =:= 0,
    even_list(T, R).
even_list([H|T], R) :-
    H mod 2 =\= 0,
    even_list(T, R).

/* 10. Count Occurrences */
count(_, [], 0).
count(X, [X|T], N) :-
    count(X, T, N1),
    N is N1 + 1.
count(X, [H|T], N) :-
    X \= H,
    count(X, T, N).

/* 11. Flatten Nested List */
flatten_list([], []).
flatten_list([H|T], R) :-
    is_list(H),
    flatten_list(H, FH),
    flatten_list(T, FT),
    my_append(FH, FT, R).
flatten_list([H|T], [H|R]) :-
    \+ is_list(H),
    flatten_list(T, R).

/* 12. Remove Duplicates */
remove_duplicates([], []).
remove_duplicates([H|T], R) :-
    my_member(H, T),
    remove_duplicates(T, R).
remove_duplicates([H|T], [H|R]) :-
    \+ my_member(H, T),
    remove_duplicates(T, R).



