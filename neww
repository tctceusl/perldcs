/* DESCENDING VERSION */

prime_factors_desc(N, L) :-
    N > 0,
    factor_store(N, 2, [], AscList),
    reverse_list(AscList, L).

factor_store(1, _, Acc, Acc) :- !.

factor_store(N, F, Acc, L) :-
    0 is N mod F, !,
    N1 is N // F,
    append(Acc, [F], NewAcc),
    factor_store(N1, F, NewAcc, L).

factor_store(N, F, Acc, L) :-
    next_factor(F, F1),
    factor_store(N, F1, Acc, L).

next_factor(2, 3) :- !.
next_factor(F, F1) :-
    F1 is F + 2.

% Reverse predicate
reverse_list(L, R) :- rev_acc(L, [], R).
rev_acc([], Acc, Acc).
rev_acc([H|T], Acc, R) :-
    rev_acc(T, [H|Acc], R).
	
	
