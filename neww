% Main predicate
queen(N) :-
    range(1, N, Columns),
    permutation(Columns, Solution),
    safe(Solution),
    write(Solution), nl.

% Check safe configuration
safe([]).
safe([Q|Qs]) :-
    safe(Qs),
    no_attack(Q, Qs, 1).

% Check diagonal and column conflicts
no_attack(_, [], _).
no_attack(Q, [Q1|Qs], Dist) :-
    Q =\= Q1,
    abs(Q - Q1) =\= Dist,
    D1 is Dist + 1,
    no_attack(Q, Qs, D1).

% Generate list 1..N
range(N, N, [N]).
range(I, N, [I|R]) :-
    I < N,
    I1 is I + 1,
    range(I1, N, R).
	
	
