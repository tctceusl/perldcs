/* ACS / STORE Version */

prime_factors_acs(N, L) :- N > 0,
    factor_store(N, 2, [], L).

factor_store(1, _, Acc, Acc) :- !.

factor_store(N, F, Acc, L) :-
    0 is N mod F, !,
    N1 is N // F,
    append(Acc, [F], NewAcc),
    factor_store(N1, F, NewAcc, L).

factor_store(N, F, Acc, L) :-
    next_factor(F, F1),
    factor_store(N, F1, Acc, L).

next_factor(2, 3) :- !.
next_factor(F, F1) :-
    F1 is F + 2.
	
	
