% Grasp banana (banana is at middle)
move(state(middle, onbox, middle, hasnot),
     grasp,
     state(middle, onbox, middle, has)).

% Climb box (monkey at box position)
move(state(P, onfloor, P, H),
     climb,
     state(P, onbox, P, H)) :-
    pos(P).

% Push box from P1 to P2 (monkey and box together, on floor)
move(state(P1, onfloor, P1, H),
     push(P1, P2),
     state(P2, onfloor, P2, H)) :-
    pos(P1), pos(P2), P1 \= P2.

% Walk from P1 to P2 (box stays)
move(state(P1, onfloor, B, H),
     walk(P1, P2),
     state(P2, onfloor, B, H)) :-
    pos(P1), pos(P2), P1 \= P2.

% Goal
canget(state(_, _, _, has)).

% Search with loop checking (Visited)
canget(State) :-
    canget(State, [State]).

canget(State, _) :-
    State = state(_, _, _, has), !.

canget(State1, Visited) :-
    move(State1, _, State2),
    \+ member(State2, Visited),
    canget(State2, [State2|Visited]).
	
	
